library(reticulate)
# Import the Python library
mid <- import("markitdown")
# Initialize the MarkItDown converter
md_converter <- mid$MarkItDown()
# Define your file paths
pdf_path <- "C:/Users/arabe/Documents/Research_Project/research papers/a contaminated reg model for count health data.pdf"
output_md_path <- "C:/Users/arabe/Documents/Research_Project/research papers/markdown files/output_note.md"
# Run the conversion
result <- md_converter$convert(pdf_path)
# Write the text content out to a .md file
writeLines(result$text_content, con = output_md_path)
cat("Conversion complete! Saved to:", output_md_path)
